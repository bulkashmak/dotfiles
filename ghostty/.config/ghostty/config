# Font
font-family = JetBrainsMono Nerd Font
font-size = 12

# Theme
theme = Monokai Remastered

# Background
# background = #141414
background-opacity = 0.8

# Other
gtk-titlebar = true

# Keybinds
## Unbind tmux/nvim
keybind = ctrl+shift+h=unbind
keybind = ctrl+shift+j=unbind
keybind = ctrl+shift+k=unbind
keybind = ctrl+shift+l=unbind
